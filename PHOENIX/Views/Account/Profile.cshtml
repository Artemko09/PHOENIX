@model PHOENIX.Models.ApplicationUser

@{
    ViewData["Title"] = "Мій профіль";
}

<div class="mx-auto max-w-4xl px-4 py-12">
    <div class="overflow-hidden rounded-3xl border border-gray-100 bg-white shadow-2xl">

        <!-- Фіксована чорна верхня панель -->
        <div class="h-32 w-full bg-black"></div>

        <div class="px-8 pb-10">
            <!-- Блок Аватара та Інформації (Центрований) -->
            <div class="relative -mt-16 mb-10 flex flex-col items-center text-center">
                
                <!-- Аватар -->
                <div class="h-32 w-32 rounded-2xl bg-white p-2 shadow-lg">
                    <div class="flex h-full w-full items-center justify-center rounded-xl bg-slate-800 text-5xl font-black tracking-tighter text-white uppercase">
                        @Model.Name?[0]
                    </div>
                </div>

                <!-- Ім'я білим кольором, що заходить на чорний фон (як на image_f629f5.png) -->
                <div class="mt-4">
                    <h1 class="text-4xl font-black tracking-tight text-gray-900 uppercase">@Model.Name</h1>
                    <p class="font-medium text-gray-500">@Model.Email</p>
                </div>

                <!-- Кнопка редагування -->
                <div class="mt-6">
                    <a asp-action="EditProfile" class="inline-flex items-center rounded-xl border-2 border-gray-900 bg-white px-6 py-2 font-bold text-gray-900 shadow-sm transition duration-200 hover:bg-gray-900 hover:text-white">
                        <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                        Редагувати профіль
                    </a>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
                <div class="space-y-6 md:col-span-2">
                    <!-- Основна інформація та Рейтинг -->
                    <div class="grid grid-cols-2 gap-6 rounded-2xl border border-gray-100 bg-gray-50 p-6">
                        <div>
                            <span class="block text-xs font-bold tracking-widest text-gray-400 uppercase">Дата народження</span>
                            <p class="text-lg font-bold text-gray-800">@Model.BirthDate.ToShortDateString()</p>
                            <p class="text-sm text-gray-500">(@Model.Age років)</p>
                        </div>
                        
                        <div>
                            <span class="block text-xs font-bold tracking-widest text-emerald-600 uppercase">Загальний рейтинг</span>
                            <p class="text-2xl font-black text-emerald-600">
                                @(Model.Achievements?.Sum(a => a.PointsEarned) ?? 0) <span class="text-sm">PTS</span>
                            </p>
                        </div>
                    </div>

                    <!-- Категорія -->
                    <div class="rounded-2xl border border-gray-100 bg-gray-50 p-6">
                        <span class="mb-1 block text-xs font-bold tracking-widest text-gray-400 uppercase">Поточна категорія</span>
                        <p class="text-2xl font-black text-gray-900">
                            @(Model.Category?.Name ?? "Не призначено")
                        </p>
                    </div>
                </div>

                <!-- Ступінь майстерності (Пояс) -->
                <div class="flex flex-col items-center justify-center rounded-2xl bg-gray-900 p-6 text-center text-white shadow-xl">
                    <span class="mb-4 text-xs font-bold tracking-widest text-gray-400 uppercase">Ступінь майстерності</span>
                    
                    @{
                        string beltIndicator = Model.SportsRank switch
                        {
                            Rank.White => "bg-gray-200",
                            Rank.Yellow => "bg-yellow-400",
                            Rank.Orange => "bg-orange-500",
                            Rank.Green => "bg-green-600",
                            Rank.Blue => "bg-blue-600",
                            Rank.Brown1 or Rank.Brown2 or Rank.Brown3 => "bg-amber-800",
                            Rank.Black => "bg-white",
                            _ => "bg-gray-500"
                        };
                    }
                    <div class="mb-4 h-3 @beltIndicator w-full rounded-full shadow-inner"></div>
                    
                    <h3 class="text-xl leading-tight font-black tracking-tighter uppercase">
                        @Model.SportsRank.GetDisplayName()
                    </h3>
                </div>
            </div>

            <!-- Історія успіху -->
            <div class="mt-12">
                <div class="mb-6 flex items-center gap-4">
                    <h2 class="text-2xl font-black tracking-tight text-gray-900 uppercase">Історія успіху</h2>
                    <div class="h-px flex-1 bg-gray-200"></div>
                </div>
                
                @if (Model.Achievements != null && Model.Achievements.Any())
                {
                    <div class="grid gap-4">
                        @foreach (var ach in Model.Achievements.OrderByDescending(a => a.Id))
                        {
                            <div class="flex items-center justify-between rounded-2xl border border-gray-100 bg-white p-5 shadow-sm transition hover:bg-gray-50">
                                <div>
                                    <h4 class="font-bold text-gray-900">@ach.Title</h4>
                                    <p class="text-xs font-medium text-gray-400 uppercase">
                                        Місце: @ach.Place | @ach.Status
                                    </p>
                                </div>
                                <div class="text-right">
                                    <span class="inline-flex items-center rounded-lg bg-gray-900 px-3 py-1 text-sm font-black text-white">
                                        +@ach.PointsEarned PTS
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="rounded-2xl border-2 border-dashed border-gray-100 p-10 text-center font-medium text-gray-400">
                        Дані про досягнення відсутні.
                    </div>
                }
            </div>
        </div>
    </div>
</div>