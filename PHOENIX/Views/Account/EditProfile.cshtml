@using PHOENIX.Models
@model PHOENIX.ViewModel.EditProfileViewModel

@{
    ViewData["Title"] = "Редагування профілю";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Оновлення даних атлета</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditProfile" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Повне ім'я</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col">
                                <label asp-for="Gender" class="form-label">Стать</label>
                                <select asp-for="Gender" asp-items="Html.GetEnumSelectList<Gender>()" class="form-select"></select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CategoryId" class="form-label">Категорія</label>
                            <select asp-for="CategoryId" class="form-select"
                                    asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                            </select>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Profile" class="btn btn-outline-secondary">Скасувати</a>
                            <button type="submit" class="btn btn-warning">Зберегти зміни</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}