@{
    ViewData["Title"] = "Рейтинг клубу PHOENIX";
    int currentUserId = ViewBag.CurrentUserId ?? 0;
    string activeTab = ViewBag.ActiveTab ?? "general";
    string targetGroup = ViewBag.TargetGroup;
    
    var generalList = ViewBag.GeneralRating as IEnumerable<PHOENIX.Models.ApplicationUser>;
    var categoryList = ViewBag.CategoryRating as IEnumerable<PHOENIX.Models.ApplicationUser>;
    var ageGroups = ViewBag.AgeGroups as List<string>;
}

<div class="mx-auto max-w-6xl px-4 py-12">
    
    <div class="mb-8 text-center">
        <h1 class="text-4xl font-black tracking-tight text-gray-900 uppercase">Турнірна Таблиця</h1>
        <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-black"></div>
    </div>

    <div class="mb-6 flex justify-center border-b border-gray-200">
        <div class="flex space-x-8">
            <a href="@Url.Action("Index", new { activeTab = "general" })"
                   class="border-b-2 pb-4 text-sm font-black tracking-wider uppercase !no-underline transition-all @(activeTab == "general" ? "border-black text-gray-900" : "border-transparent text-gray-400 hover:text-gray-600")">
                 Загальний рейтинг
            </a>
            <a href="@Url.Action("Index", new { activeTab = "category", targetGroup = targetGroup })"
                   class="border-b-2 pb-4 text-sm font-black tracking-wider uppercase !no-underline transition-all @(activeTab == "category" ? "border-emerald-500 text-emerald-600" : "border-transparent text-gray-400 hover:text-gray-600")">
                 Рейтинг за віковими групами
            </a>
        </div>
    </div>

    @if (activeTab == "category")
    {
        <div class="mx-auto mb-6 flex max-w-2xl flex-col items-center justify-center gap-3 rounded-2xl border border-gray-100 bg-gray-50 p-4 sm:flex-row">
            <span class="text-xs font-black tracking-wider whitespace-nowrap text-gray-500 uppercase">Оберіть вікову групу:</span>
            <form method="get" asp-action="Index" class="flex w-full items-center sm:w-auto">
                <input type="hidden" name="activeTab" value="category" />
                <select name="targetGroup" onchange="this.form.submit()" class="w-full rounded-xl border-gray-200 bg-white p-2 text-sm font-bold text-gray-700 shadow-sm focus:border-black focus:ring-black sm:w-72">
                    @foreach (var group in ageGroups)
                    {
                        if (targetGroup == group)
                        {
                            <option value="@group" selected="selected">@group</option>
                        }
                        else
                        {
                            <option value="@group">@group</option>
                        }
                    }
                </select>
            </form>
        </div>
    }

    <div class="overflow-hidden rounded-3xl border border-gray-100 bg-white shadow-2xl">
        <div class="overflow-x-auto">
            <table class="w-full min-w-[800px] border-collapse text-left">
                <thead>
                    <tr class="bg-gray-900 text-xs font-bold tracking-widest text-white uppercase">
                        <th class="w-24 p-5 text-center">Місце</th>
                        <th class="w-1/4 p-5">Атлет</th>
                        <th class="w-1/3 p-5">Категорія (Турнірна)</th>
                        <th class="p-5">Пояс</th>
                        <th class="w-36 p-5 text-right">Бали (PTS)</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @{
                        var currentDisplayList = activeTab == "general" ? generalList : categoryList;
                        int rankPosition = 1;
                    }

                    @if (currentDisplayList != null && currentDisplayList.Any())
                    {
                        @foreach (var user in currentDisplayList)
                        {
                            var totalPoints = user.Achievements?.Sum(a => a.PointsEarned) ?? 0;
                            bool isCurrentUser = user.Id == currentUserId;

                            <tr class="transition duration-150 @(isCurrentUser ? "bg-emerald-50/60 font-semibold" : "hover:bg-gray-50/80")">
                                <td class="p-5 text-center text-lg font-black">
                                    @if (rankPosition == 1)
                                    {
                                        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-amber-400 text-sm font-bold text-black shadow-sm">1</span>
                                    }
                                    else if (rankPosition == 2)
                                    {
                                        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-slate-200 text-sm font-bold text-slate-800 shadow-sm">2</span>
                                    }
                                    else if (rankPosition == 3)
                                    {
                                        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-amber-600 text-sm font-bold text-amber-50 shadow-sm">3</span>
                                    }
                                    else
                                    {
                                        <span class="text-base text-gray-400">@rankPosition</span>
                                    }
                                </td>

                                <td class="p-5">
                                    <div class="flex items-center gap-4">
                                        <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl bg-slate-800 text-sm font-black text-white uppercase shadow-sm">
                                            @user.Name?[0]
                                        </div>
                                        <div class="whitespace-nowrap">
                                            <span class="inline-flex items-center gap-2 text-base font-bold text-gray-900">
                                                @user.Name
                                                @if (isCurrentUser)
                                                {
                                                    <span class="rounded bg-emerald-500 px-2 py-0.5 font-black tracking-wide text-[10px] text-white uppercase shadow-sm">Це ти</span>
                                                }
                                            </span>
                                        </div>
                                    </div>
                                </td>

                                <td class="p-5 text-sm font-semibold tracking-tight text-gray-600 uppercase">
                                    @(user.Category?.Name ?? "Не призначено")
                                </td>

                                <td class="p-5 text-sm font-bold tracking-tight text-gray-700 uppercase">
                                    @user.SportsRank.GetDisplayName()
                                </td>

                                <td class="p-5 text-right text-xl font-black @(totalPoints > 0 ? "text-emerald-600" : "text-gray-300")">
                                    @totalPoints
                                </td>
                            </tr>

                            rankPosition++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="p-10 text-center text-sm font-bold tracking-wider text-gray-400 uppercase">
                                В цій віковій групі ще немає жодного атлета
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>