@model IEnumerable<PHOENIX.Models.News>

@{
    ViewData["Title"] = "Новини клубу";
}

<div class="mx-auto max-w-5xl px-4 py-8">
    <div class="mb-10 flex items-center justify-between">
        <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Новини клубу</h1>
        
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="inline-flex items-center rounded-lg bg-emerald-600 px-5 py-2.5 font-medium text-white shadow-md transition duration-200 hover:bg-emerald-700">
                <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Створити новину
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 p-12 text-center">
            <p class="text-lg text-gray-500">Поки що новин немає. Заходьте пізніше!</p>
        </div>
    }
    else
    {
        <div class="space-y-6">
            @foreach (var item in Model)
            {
                <div class="overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition-shadow duration-300 hover:shadow-md">
                    <div class="p-6 md:p-8">
                        <div class="mb-4 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                            <h3 class="text-2xl font-bold text-gray-800">@item.Title</h3>
                            <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-500">
                                <svg class="mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </span>
                        </div>
                        
                        <p class="text-lg leading-relaxed whitespace-pre-line text-gray-600">@item.Content</p>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="mt-6 flex justify-end gap-3 border-t border-gray-50 pt-4">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="rounded-md px-3 py-1.5 font-medium text-amber-600 transition hover:bg-amber-50">Редагувати</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="rounded-md px-3 py-1.5 font-medium text-red-600 transition hover:bg-red-50">Видалити</a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>