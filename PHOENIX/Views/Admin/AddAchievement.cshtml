@model PHOENIX.Models.Achievement

<div class="mx-auto max-w-3xl px-6 py-12">
    <div class="overflow-hidden rounded-3xl border border-gray-100 bg-white shadow-2xl">
        <!-- Заголовок -->
        <div class="bg-gray-900 px-8 py-6">
            <h1 class="text-xl font-black tracking-widest text-white uppercase">Додати досягнення</h1>
            <p class="mt-1 text-sm text-gray-400">Атлет: <span class="font-bold text-emerald-400">@ViewBag.UserName</span></p>
        </div>

        <form asp-action="AddAchievement" method="post" class="space-y-6 p-8">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />

            <!-- Назва події -->
            <div class="space-y-2">
                <label asp-for="Title" class="ml-1 text-xs font-black text-gray-400 uppercase">Назва турніру або заходу</label>
                <input asp-for="Title" placeholder="Наприклад: Чемпіонат України 2026"
                       class="w-full rounded-2xl border-2 border-gray-100 px-5 py-4 font-bold text-gray-700 placeholder-gray-300 transition-all focus:border-emerald-500 focus:ring-0" />
                <span asp-validation-for="Title" class="ml-1 text-xs font-bold text-red-500"></span>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <!-- Статус змагань -->
                <div class="space-y-2">
                    <label asp-for="Status" class="ml-1 text-xs font-black text-gray-400 uppercase">Статус (Коефіцієнт)</label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<PHOENIX.Models.TournamentStatus>()"
                            class="w-full px-5 py-4 rounded-2xl border-2 border-gray-100 focus:border-emerald-500 focus:ring-0 transition-all font-bold text-gray-700 cursor-pointer">
                    </select>
                </div>

                <!-- Дата -->
                <div class="space-y-2">
                    <label asp-for="Date" class="ml-1 text-xs font-black text-gray-400 uppercase">Дата проведення</label>
                    <input asp-for="Date" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")"
                           class="w-full rounded-2xl border-2 border-gray-100 px-5 py-4 font-bold text-gray-700 transition-all focus:border-emerald-500 focus:ring-0" />
                </div>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <!-- Зайняте місце -->
                <div class="space-y-2">
                    <label asp-for="Place" class="ml-1 text-xs font-black text-gray-400 uppercase">Місце (0 для "Участь")</label>
                    <input asp-for="Place" type="number" min="0"
                           class="w-full rounded-2xl border-2 border-gray-100 px-5 py-4 font-bold text-gray-700 transition-all focus:border-emerald-500 focus:ring-0" />
                </div>

                <!-- Кількість учасників -->
                <div class="space-y-2">
                    <label asp-for="ParticipantsCount" class="ml-1 text-xs font-black text-gray-400 uppercase">Учасників у категорії</label>
                    <input asp-for="ParticipantsCount" type="number" min="1"
                           class="w-full rounded-2xl border-2 border-gray-100 px-5 py-4 font-bold text-gray-700 transition-all focus:border-emerald-500 focus:ring-0" />
                </div>
            </div>

            <!-- Кнопка збереження -->
            <div class="pt-6">
                <button type="submit" class="group relative inline-flex w-full items-center justify-center overflow-hidden rounded-2xl bg-gray-900 px-8 py-5 font-black text-white shadow-xl transition-all hover:bg-emerald-600 active:scale-[0.98]">
                    <span class="relative text-sm tracking-widest uppercase">Зберегти та розрахувати рейтинг</span>
                </button>
                <a asp-action="Users" class="mt-4 block text-center text-xs font-black text-gray-400 uppercase transition-colors hover:text-gray-600">
                    Скасувати та повернутися
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}