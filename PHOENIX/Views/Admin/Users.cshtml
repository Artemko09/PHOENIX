@using PHOENIX.Models
@model IEnumerable<PHOENIX.Models.ApplicationUser>

<div class="mx-auto max-w-7xl px-4 py-10">
    <div class="mb-8 flex items-center justify-between">
        <h1 class="text-3xl font-black tracking-tighter text-gray-900 uppercase">Реєстр Атлетів</h1>
        <span class="rounded-full bg-emerald-100 px-4 py-1 text-sm font-bold text-emerald-700">
            Всього: @Model.Count()
        </span>
    </div>

    <div class="overflow-hidden rounded-3xl border border-gray-100 bg-white shadow-2xl">
        <table class="w-full border-collapse text-left">
            <thead class="bg-gray-900 text-xs tracking-[0.2em] text-white uppercase">
                <tr>
                    <th class="px-6 py-5">Прізвище та ім'я</th>
                    <th class="px-6 py-5">Поточний пояс</th>
                    <th class="px-6 py-5 text-center">Рейтинг (PTS)</th>
                    <th class="px-6 py-5 text-right">Дії</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var user in Model)
                {
                    <tr class="transition duration-150 hover:bg-gray-50">
                        <td class="px-6 py-4">
                            <div class="text-lg font-bold text-gray-900">@user.Name</div>
                            <div class="text-xs font-medium text-gray-400">@user.Email</div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center rounded-lg border border-gray-200 bg-gray-50 px-3 py-1 text-xs font-black text-gray-700 uppercase">
                                @user.SportsRank.GetDisplayName()
                            </span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            @* Виводимо суму балів, яку ми порахували через Achievements *@
                            <span class="text-xl font-black text-emerald-600">
                                @(user.Achievements?.Sum(a => a.PointsEarned) ?? 0)
                            </span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-3">
                                
                                @if (User.IsInRole("Admin"))
                                {
                                    @* Кнопка швидкого додавання досягнення *@
                                    <a asp-action="AddAchievement" asp-route-userId="@user.Id"
                                           class="inline-flex items-center gap-1 rounded-xl bg-emerald-50 px-3 py-2 text-xs font-black text-emerald-700 uppercase shadow-sm transition-all hover:bg-emerald-600 hover:text-white">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path>
                                        </svg>
                                        Досягнення
                                    </a>

                                    @* Форма зміни поясу *@
                                    <form asp-action="UpdateRank" method="post" class="inline-flex items-center gap-2">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <select name="newRank" asp-items="Html.GetEnumSelectList<Rank>()"
                                                class="text-xs py-2 pl-3 pr-8 border-gray-200 rounded-xl focus:ring-emerald-500 focus:border-emerald-500 font-bold text-gray-700">
                                        </select>
                                        <button type="submit" title="Оновити пояс" class="rounded-xl bg-gray-900 p-2 text-white shadow-md transition-all hover:bg-blue-600 active:scale-95">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                            </svg>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>